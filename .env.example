# Gemini API Key (get one at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model name
GEMINI_MODEL=gemini-2.5-flash

# Upload directory (relative to project root)
UPLOAD_DIR=uploads

# Max upload file size in megabytes
MAX_FILE_SIZE_MB=25
MAX_VIDEO_SIZE_MB=300

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Whisper / HSEmotion / video sampling
WHISPER_MODEL_SIZE=base
HSEMOTION_MODEL_NAME=enet_b0_8_best_afew
VIDEO_SAMPLE_FRAME_COUNT=60

# Session persistence (PostgreSQL). Uses the psycopg3 driver.
DATABASE_URL=postgresql+psycopg://futureready:futureready@localhost:5432/futureready

# Stamped onto every ScoreResult/PreliminaryEvaluation/UnifiedFeature row,
# so historical scores stay attributable to the exact formula revision that
# produced them even after the Scoring Engine / Feature Fusion Engine is
# later updated.
SCORING_ENGINE_VERSION=1.0.0
FEATURE_FUSION_VERSION=1.0.0
